---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Sheet from '../../components/Sheet.astro';
import Footer from '../../components/Footer.astro';
import facts from '../../content/facts';

const chromeStoreUrl = 'https://chromewebstore.google.com/detail/verso/celmibcnighdegjjcipimmdkjikhkdjm';

const demo = facts.sheetTravel;
const isDraft = !demo;
---

<Layout
  title="Verso for Travel — See what a second model recommends"
  description="AI models recommend different hotels, flights, and restaurants with total confidence. Verso shows you what another model says before you book."
  ogTitle="Verso for Travel"
  ogDescription="Every hotel recommendation comes from a model that's never slept there."
  noindex={isDraft}
  includeScrollReveal
  includeSheet={!!demo}
>

<Nav variant="consumer" />

<header class="vs-hero">
  <div class="vs-wrap vs-hero-grid">
    <div>
      <div class="vs-eyebrow vs-rise"><em></em><span class="vs-mono">Travel</span></div>

      <h1 class="vs-h1 vs-rise">
        <span class="rec">The model has</span>
        <span class="rec">never been</span>
        <span class="ver">there</span>
      </h1>

      <p class="vs-lede vs-rise">
        You ask where to stay in Lisbon. The model picks a hotel with total confidence.
        A second model picks a <b>different neighborhood entirely</b>. Neither has been to Lisbon.
        But when two models disagree, at least you know to check.
      </p>

      <div class="vs-actions vs-rise" id="install">
        <a class="vs-btn" href={chromeStoreUrl}>
          Add to Chrome
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
            <path d="M1 12L12 1M12 1H4M12 1v8" stroke="currentColor" stroke-width="1.7"/>
          </svg>
        </a>
        <span class="vs-note"><b>Free.</b> Works on ChatGPT, Claude, Gemini, Perplexity.</span>
      </div>
    </div>

    {demo && (
      <Sheet
        front={{
          label: 'Model A',
          side: 'Recto',
          questionPrefix: 'You asked:',
          question: demo.question,
          answer: demo.modelA.answer,
          answerMark: demo.modelA.mark,
          closing: demo.modelA.closing,
          flipCue: 'Turn the page',
          verdict: '1 of 2',
        }}
        back={{
          label: 'Model B',
          side: 'Verso',
          questionPrefix: 'Same question:',
          question: demo.question,
          answer: demo.modelB.answer,
          answerMark: demo.modelB.mark,
          closing: demo.modelB.closing,
          flipCue: 'Turn back',
          verdict: demo.verdict,
        }}
      />
    )}
  </div>
</header>

<section class="vs-band" aria-hidden="true">
  <div class="vs-marquee">
    <p>
      <span>One says Alfama</span><span>The other says Príncipe Real</span><span>Same city, different trip</span><span>Neither has been there</span>
      <span>One says Alfama</span><span>The other says Príncipe Real</span><span>Same city, different trip</span><span>Neither has been there</span>
    </p>
  </div>
</section>

<section class="vs-steps" id="how">
  <div class="vs-wrap">
    <div class="vs-shead vs-rise">
      <span class="vs-mono">Why it matters</span>
      <h2>Travel advice is where model confidence is most dangerous.</h2>
      <p>Hotels close. Restaurants change owners. Flight routes get canceled. Models don't know any of this — they pattern-match on training data and present the result as if they just got back from the trip. A second opinion doesn't guarantee accuracy, but it exposes the gaps. When one model recommends a "quiet boutique hotel" and the other calls the same neighborhood noisy and overpriced, you know at least one of them is guessing.</p>
    </div>

    <div class="vs-steplist">
      <div class="vs-step vs-rise">
        <span class="vs-stepnum">STEP 01</span>
        <h3>Install once</h3>
        <p>Verso opens as a side panel next to ChatGPT, Claude, Gemini, and Perplexity. Nothing to configure.</p>
      </div>
      <div class="vs-step vs-rise">
        <span class="vs-stepnum">STEP 02</span>
        <h3>Plan your trip</h3>
        <p>Ask about hotels, restaurants, itineraries, flights — the way you already do. Verso watches for questions where a second perspective matters.</p>
      </div>
      <div class="vs-step vs-rise">
        <span class="vs-stepnum">STEP 03</span>
        <h3>See the other itinerary</h3>
        <p>Your question goes to a second model. Two sets of recommendations, side by side. Agreement tells you something. Disagreement tells you more.</p>
      </div>
    </div>
  </div>
</section>

<section class="vs-trans" id="data">
  <div class="vs-wrap vs-transgrid">
    <div class="vs-rise">
      <span class="vs-mono">The deal</span>
      <h2>Verso is free because <u>preference is worth something.</u></h2>
    </div>
    <div class="vs-rise">
      <p>When you pick one travel recommendation over another, you answer a question that matters to the industry: which model do travelers actually trust? We collect your prompts, both answers, and your preference. We sell the measurement — not the conversations.</p>

      <a class="vs-labslink" href="/what-we-collect">
        Read exactly what we collect and what we sell
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <path d="M1 6.5h11M7.5 2l4.5 4.5L7.5 11" stroke="currentColor" stroke-width="1.6"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<section class="vs-close">
  <div class="vs-wrap vs-rise">
    <h2>Get the <u>other itinerary.</u></h2>
    <p>One click, one second opinion. Before you book on a model's word, see what another model says about the same place.</p>
    <a class="vs-btn" href={chromeStoreUrl}>
      Add to Chrome — free
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
        <path d="M1 12L12 1M12 1H4M12 1v8" stroke="currentColor" stroke-width="1.7"/>
      </svg>
    </a>
  </div>
</section>

<Footer links={[
  { href: '/', label: 'Extension' },
  { href: '/what-we-collect', label: 'What we collect' },
  { href: '/privacy', label: 'Privacy' },
  { href: 'mailto:contact@tryverso.ai', label: 'Contact' },
]} />

</Layout>
