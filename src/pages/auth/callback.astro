---
// Auth callback handler — self-contained page, does not use main Layout.
// Receives Google OAuth response, sends tokens to extension if applicable.
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Sign in — Verso</title>

<link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32.png">
<link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/styles/tokens.css">
<style>
  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--paper);
    font-family: var(--fb);
    color: var(--ink);
  }
  .vs-auth-card {
    background: var(--sheet);
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(20,21,26,.08);
    padding: 40px 32px;
    max-width: 360px;
    width: 100%;
    margin: 0 16px;
    text-align: center;
  }
  .vs-auth-title {
    font-family: var(--fb);
    font-weight: 600;
    font-size: 1.25rem;
    margin: 0 0 8px;
  }
  .vs-auth-msg {
    font-size: 0.875rem;
    color: var(--ink-soft);
    margin: 0 0 24px;
  }
  .vs-auth-msg--error {
    color: #dc2626;
  }
  .vs-spinner {
    width: 24px;
    height: 24px;
    border: 2px solid var(--rule);
    border-top-color: var(--blue);
    border-radius: 50%;
    animation: vs-spin .6s linear infinite;
    margin: 0 auto;
  }
  @keyframes vs-spin { to { transform: rotate(360deg); } }
  .vs-icon-ok {
    width: 40px;
    height: 40px;
    color: #16a34a;
    margin: 0 auto;
  }
  .vs-btn {
    display: inline-block;
    padding: 10px 20px;
    background: var(--blue);
    color: #fff;
    font-family: var(--fm);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity .15s;
    margin: 4px;
  }
  .vs-btn:hover { opacity: .85; }
  .vs-btn--ghost {
    background: transparent;
    color: var(--ink-soft);
  }
  .vs-btn--ghost:hover { color: var(--ink); }
  .vs-hidden { display: none; }
  .vs-actions { display: flex; flex-direction: column; gap: 8px; align-items: center; }
</style>
</head>
<body>

<div class="vs-auth-card">
  <h1 id="title" class="vs-auth-title">Signing in...</h1>
  <p id="msg" class="vs-auth-msg">Processing sign-in...</p>

  <div id="spinner" class="vs-spinner"></div>

  <svg id="icon-ok" class="vs-icon-ok vs-hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
    <polyline points="22 4 12 14.01 9 11.01"/>
  </svg>

  <div id="actions" class="vs-actions vs-hidden">
    <button class="vs-btn" onclick="location.href='/auth'+window.location.search">Try again</button>
    <button class="vs-btn vs-btn--ghost" onclick="window.close()">Close</button>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script is:inline>
(function () {
  var SUPABASE_URL = 'https://pnegsckjwdqiescywcna.supabase.co';
  var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBuZWdzY2tqd2RxaWVzY3l3Y25hIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzAwNDk2OTgsImV4cCI6MjA4NTYyNTY5OH0.pSx5MmWVn3FbLMe5ZFjo5hIJsVxUNIJrMRfhw3OX96s';
  var DEFAULT_EXTENSION_ID = 'celmibcnighdegjjcipimmdkjikhkdjm';

  var titleEl   = document.getElementById('title');
  var msgEl     = document.getElementById('msg');
  var spinnerEl = document.getElementById('spinner');
  var iconOkEl  = document.getElementById('icon-ok');
  var actionsEl = document.getElementById('actions');

  function showError(text) {
    titleEl.textContent = 'Sign-in failed';
    msgEl.textContent = text;
    msgEl.classList.add('vs-auth-msg--error');
    spinnerEl.classList.add('vs-hidden');
    actionsEl.classList.remove('vs-hidden');
  }

  function showSuccess(text) {
    titleEl.textContent = 'Welcome to Verso';
    msgEl.textContent = text;
    spinnerEl.classList.add('vs-hidden');
    iconOkEl.classList.remove('vs-hidden');
  }

  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY, {
    auth: { storage: window.localStorage, persistSession: true, autoRefreshToken: true }
  });

  var params = new URLSearchParams(window.location.search);
  var isExtension = params.get('extension') === 'true';
  var extId = params.get('ext_id') || DEFAULT_EXTENSION_ID;

  function sendTokensToExtension(accessToken, refreshToken, user) {
    return new Promise(function (resolve) {
      if (typeof chrome === 'undefined' || !chrome.runtime || !chrome.runtime.sendMessage) {
        console.log('Verso: Chrome runtime not available');
        resolve(false);
        return;
      }
      chrome.runtime.sendMessage(extId, {
        type: 'verso-auth-tokens',
        access_token: accessToken,
        refresh_token: refreshToken,
        user: user
      }, function (response) {
        if (chrome.runtime.lastError) {
          console.log('Verso: Extension not reachable —', chrome.runtime.lastError.message);
          resolve(false);
          return;
        }
        resolve(response && response.success === true);
      });
    });
  }

  sb.auth.getSession().then(function (result) {
    if (result.error || !result.data.session) {
      console.error('Verso: Auth callback error:', result.error);
      showError((result.error && result.error.message) || 'Failed to complete sign-in. Please try again.');
      return;
    }

    var session = result.data.session;

    if (isExtension) {
      msgEl.textContent = 'Sending credentials to Verso extension...';

      sendTokensToExtension(session.access_token, session.refresh_token, session.user)
        .then(function (sent) {
          if (sent) {
            showSuccess('Sign-in successful! Closing...');
            setTimeout(function () { window.close(); }, 500);
            setTimeout(function () {
              msgEl.textContent = 'Sign-in successful! You can close this tab.';
            }, 1500);
          } else {
            showSuccess('Signed in successfully. If the extension didn\'t update, please reopen it.');
          }
        });
    } else {
      showSuccess('Sign-in successful!');
    }
  }).catch(function (e) {
    console.error('Verso: Auth callback error:', e);
    showError('Something went wrong. Please try again.');
  });
})();
</script>
</body>
</html>
